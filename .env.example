# ARC Testnet Private Key (for contract deployment - NOT needed for frontend)
ARC_TESTNET_PRIVATE_KEY=

# Treasury Contract Address (deployed on ARC Testnet)
NEXT_PUBLIC_TREASURY_ADDRESS=0x32faE7187a00f096B0536Ad4872fb324Bae39671

# ARC Network RPC
NEXT_PUBLIC_ARC_RPC=https://rpc.testnet.arc.network

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=arc-agent-treasury-demo

# Circle Developer Platform (for managed wallets - optional)
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
