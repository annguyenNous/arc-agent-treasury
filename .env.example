# ============================================
# CREDENTIALS (NEVER commit to git)
# ============================================

# Private key for contract deployment + AI agent wallet
# Used by: hardhat.config.ts, scripts/run-agent.ts, src/agent/config.ts
AGENT_PRIVATE_KEY=

# Anthropic API key for AI agent (Claude 3.5 Sonnet)
# Used by: src/agent/TreasuryAgent.ts
ANTHROPIC_API_KEY=

# API secret for REST endpoint authentication
# Used by: src/app/api/middleware.ts
API_SECRET=

# ============================================
# NETWORK CONFIG
# ============================================

# ARC Network RPC
NEXT_PUBLIC_ARC_RPC=https://rpc.testnet.arc.network

# ARC Testnet Chain ID
NEXT_PUBLIC_CHAIN_ID=5042002

# Treasury Contract Address (deployed on ARC Testnet)
NEXT_PUBLIC_TREASURY_ADDRESS=0x32faE7187a00f096B0536Ad4872fb324Bae39671

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=arc-agent-treasury-demo

# ============================================
# OPTIONAL
# ============================================

# Circle Developer Platform (for managed wallets - optional)
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
